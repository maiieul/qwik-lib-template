{
  "name": "qwik-lib-template",
  "version": "0.0.1",
  "private": true,
  "description": "Opinionated Qwik library template — a living reference maintained by the Qwik core team",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter playground dev",
    "build": "pnpm --filter './packages/*' build",
    "check": "vp check . && pnpm -r run check",
    "fix": "vp check --fix .",
    "lint": "vp lint .",
    "fmt": "vp fmt .",
    "fmt.check": "vp fmt --check .",
    "test": "vp test",
    "test.unit": "vp test --project node",
    "test.browser": "vp test --project dom",
    "test.watch": "vp test watch",
    "prepare": "vp config --hooks-only"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@qwik.dev/core": "catalog:",
    "@types/node": "catalog:",
    "axe-core": "4.12.0",
    "oxlint-plugin-qwik": "0.0.8",
    "pkg-pr-new": "0.0.75",
    "playwright": "1.60.0",
    "publint": "0.3.21",
    "rolldown": "catalog:",
    "sherif": "1.11.1",
    "typescript": "catalog:",
    "vite-plus": "0.1.24",
    "vitest": "*",
    "vitest-browser-qwik": "catalog:"
  },
  "engines": {
    "node": ">=22.12"
  },
  "packageManager": "pnpm@10.28.2"
}
